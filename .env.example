# --- App ---
# APP_ENV: dev | prod
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database (Postgres / Supabase) ---
# Para Supabase: postgresql+asyncpg://postgres:<pass>@db.<project>.supabase.co:5432/postgres
# Para local docker-compose: postgresql+asyncpg://tmjr:tmjr@db:5432/tmjr
DATABASE_URL=postgresql+asyncpg://tmjr:tmjr@db:5432/tmjr

# --- Telegram ---
# Vacío => API-only, sin bot. Útil para tests.
TELEGRAM_TOKEN=
# URL pública (https) por la que Telegram entrega los Update.
TELEGRAM_WEBHOOK_URL=
# Secret token para validar X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Path DENTRO DEL CONTENEDOR al cert público (PEM) que se sube a Telegram.
# Solo necesario si nginx termina TLS con cert self-signed. Vacío → no se sube.
TELEGRAM_WEBHOOK_CERT_FILE=/app/certs/nginx.pem
# Canal donde se publican las sesiones.
TELEGRAM_CHAT_ID=
# Opcional: id del topic si el canal es modo foro.
TELEGRAM_THREAD_ID=
